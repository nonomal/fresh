# Tiltfile syntax highlighting test
docker_build('myapp', '.')

k8s_yaml('k8s/deployment.yaml')

k8s_resource(
    'myapp',
    port_forwards='8080:8080',
    resource_deps=['database'],
)

local_resource(
    'generate-protos',
    cmd='make proto',
    deps=['proto/'],
)

if config.tilt_subcommand == 'up':
    print("Starting development environment")
