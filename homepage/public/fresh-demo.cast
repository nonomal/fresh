[39.56198933799999, "o", "\u001b[2;1H\u001b[1m\u001b[38;5;235;48;5;253m main.rs \u00d7 \u001b[2;26H\u001b[22m\u001b[38;5;240;48;5;253m *Preview* \u00d7 \u001b[2;52H\u001b[38;5;241;48;5;250m\u25a1\u001b[2;54H\u00d7\u001b[2;56H\u001b[38;5;244;49m\u2502\u001b[1m\u001b[38;5;235;48;5;231m *Preview* \u00d7 \u001b[2;107H\u001b[22m\u001b[38;5;241;48;5;250m\u25a1\u001b[2;109H\u00d7\u001b[3;47H\u001b[39;48;5;231m        \u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;254m  main.rs:7:12\u001b[39;48;5;254m                                       \u001b[4;5H\u001b[38;5;242;48;5;231m \u001b[4;9H\u001b[38;5;28;48;5;231mfeatures.\u001b[4;55H\u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;231m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[5;5H\u001b[38;5;242;48;5;231m2\u001b[5;9H\u001b[39;48;5;231m                              \u001b[5;55H\u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;231m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[6;5H\u001b[38;5;242;48;5;231m3\u001b[6;9H\u001b[38;5;128;48;5;231muse\u001b[38;5;16;48;5;231m std\u001b[38;5;236;48;5;231m::\u001b[38;5;16;48;5;231mcollections\u001b[38;5;236;48;5;231m::\u001b[38;5;16;48;5;231mHashMap\u001b[38;5;236;48;5;231m;\u001b[6;55H\u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;231m     2 \u2502 \u001b[7;5H\u001b[38;5;242;48;5;231m4\u001b[7;9H\u001b[39;48;5;231m                                    \u001b[7;55H\u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;231m     3 \u2502 use std::collections::HashMap;\u001b[8;5H\u001b[38;5;242;48;5;231m5\u001b[8;9H\u001b[38;5;28;48;5;231m/// A simple user management system.\u001b[8;55H\u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;231m     4 \u2502 \u001b[9;1H\u001b[39;48;5;231m \u001b[38;5;242;48;5;231m   6 \u2502 \u001b[38;5;16;48;5;231m#\u001b[38;5;236;48;5;231m[\u001b[38;5;18;48;5;231mderive\u001b[38;5;236;48;5;231m(\u001b[38;5;16;48;5;231mDebug\u001b[38;5;236;48;5;231m,\u001b[38;5;16;48;5;231m Clone\u001b[38;5;236;48;5;231m)]\u001b[39;48;5;231m                       \u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;231m     5 \u2502 /// A simple user management system.\u001b[39;48;5;231m        \u001b[10;1H\u001b[38;5;242;48;5;231m\u25be\u001b[10;5H7\u001b[10;9H\u001b[38;5;128;48;5;231mpub\u001b[38;5;16;48;5;248m \u001b[38;5;30;48;5;231mstruct\u001b[38;5;16;48;5;231m \u001b[38;5;30;48;5;231mUser\u001b[38;5;16;48;5;231m \u001b[38;5;236;48;5;231m{\u001b[10;55H\u001b[39;48;5;8m \u001b[38;5;244;49m\u2502\u001b[38;5;16;48;5;"]
